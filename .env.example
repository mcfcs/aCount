# aCount — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---- Flask ----------------------------------------------------------------
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# ---- API security ---------------------------------------------------------
# When set, every /api/* request must send header `X-API-Key: <API_KEY>`.
# Set the SAME value as VITE_API_KEY in frontend/.env so the UI can call the API.
# Leave blank for unauthenticated local development.
API_KEY=
# Comma-separated browser origins allowed to call /api/* (CORS).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set to true ONLY if you want the destructive /api/settings/reset enabled.
ALLOW_DB_RESET=false
# Host/port for `python run.py` (defaults to localhost-only).
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

# ---- Database -------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://acount_user:acount_pass@localhost:5432/acount_db

# For running tests (uses SQLite by default, override with a test PG db if needed)
# TEST_DATABASE_URL=postgresql://acount_user:acount_pass@localhost:5432/acount_test_db

# ---- Barcode scanning -------------------------------------------------------
# UPCitemdb key for the paid tier. Leave blank to use the keyless free trial
# (~100 lookups/day per IP) — enough for personal use since confirmed scans
# are cached in the local product_barcodes table.
UPCITEMDB_API_KEY=

# ---- Gmail API (Section 3.5) ----------------------------------------------
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-stored-refresh-token
GMAIL_POLL_INTERVAL_SECONDS=300   # default: every 5 minutes